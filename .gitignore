# Unity Standard GitIgnore
# See: https://github.com/github/gitignore/blob/main/Unity.gitignore

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]serSettings/

# Memory Captures
[Mm]emoryCaptures/

# Asset Checksum
Assets/*.asset.metadata

# Autogenerated JetBrains Rider project files
.idea/
*.sln
*.csproj
*.unityproj

# OS X
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a project folder
/.vs/
/GeneratedUI/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Unity WebGL
[Aa]ssets/[Ww]ebGLTemplates/*/

# Recorded simulations
[Rr]ecordings/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.unitypackage
